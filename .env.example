# Active LLM provider
LLM_PROVIDER=deepseek          # deepseek | anthropic | openai | ollama

# DeepSeek (default)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Web search (used by all providers except Anthropic)
WEB_SEARCH_PROVIDER=tavily    # tavily | serpapi
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/company_intel

# Server
PORT=3004
